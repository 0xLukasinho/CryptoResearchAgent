# === Required for Claude Max subscription billing ===
# Run `claude setup-token` once to authenticate via OAuth — claude -p will
# pick up the credential automatically. There is no env var to set here.

# === Required: external (non-Claude) APIs ===
SUPADATA_API_KEY=your-supadata-api-key-here
CLOUDCONVERT_API_KEY=your-cloudconvert-api-key-here
YOUTUBE_API_KEY=your-youtube-api-key-here

# === DO NOT set ANTHROPIC_API_KEY ===
# claude -p prefers ANTHROPIC_API_KEY over OAuth/subscription auth when
# both are present, which routes calls through the pay-per-token API
# instead of your subscription. The pipeline does not use this key for
# any production code path, and ClaudeCodeBackend explicitly strips it
# from its subprocess env as defense in depth.
